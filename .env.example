# ============================================================
# ASEC Document Extraction Pipeline — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.
# ============================================================

# Ollama host URL (optional — defaults to http://localhost:11434)
# OLLAMA_HOST=http://localhost:11434

# Ollama model to use (optional — defaults to llama3.1:8b)
# Pull it first:  ollama pull llama3.1:8b
# Other options:  qwen2.5:7b  |  mistral:7b-instruct  |  deepseek-r1:8b
# OLLAMA_MODEL=llama3.1:8b

# OpenRouter Cloud API (optional — if set, overrides local Ollama)
# OR_API=sk-or-v1-your-key-here
# OR_MODEL=google/gemini-2.0-flash-001

# Windows only: Full path to tesseract.exe if not on system PATH
# Example: C:\Program Files\Tesseract-OCR\tesseract.exe
# TESSERACT_CMD=

# Tesseract OCR language(s). Defaults to English.
# Use '+'-separated codes for multi-language, e.g. eng+ara
# TESSERACT_LANG=eng

# Windows only: Full path to Poppler's bin/ folder if not on system PATH
# Example: C:\poppler\Library\bin
# POPPLER_PATH=
